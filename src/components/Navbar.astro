---
import ThemeToggle from "./ThemeToggle.astro";

const navLinks = [
  { href: "/", label: "Projects" },
  { href: "/blog", label: "Blog" },
  { href: "/about", label: "About" },
];

const currentPath = Astro.url.pathname;
---

<nav
  class="sticky top-0 z-50 backdrop-blur-md bg-sand-50/80 dark:bg-stone-950/80 border-b border-sand-200 dark:border-stone-700"
>
  <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
    <a
      href="/"
      class="text-xl font-bold text-stone-900 dark:text-sand-100 hover:text-sage-600 dark:hover:text-sage-400 transition-colors"
    >
      Nicholas M. Kasten
    </a>

    <div class="flex items-center gap-6">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              "text-sm font-medium transition-colors",
              currentPath === link.href
                ? "text-sage-600 dark:text-sage-400"
                : "text-stone-600 dark:text-sand-300 hover:text-sage-600 dark:hover:text-sage-400",
            ]}
          >
            {link.label}
          </a>
        ))
      }
      <ThemeToggle />
    </div>
  </div>
</nav>
